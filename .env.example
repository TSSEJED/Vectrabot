# 📡 Vectrabot Environment Configurations Blueprint
# Copy this file to .env and insert your specific API secrets and configuration keys.
# Do NOT commit your actual .env file to public version control systems.

# Discord Bot Gateway Token (from Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=your_discord_bot_secret_token_here

# Discord Client Application ID (from Discord Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=your_discord_application_id_here

# The display name for your bot (used in user-facing command messages)
BOT_NAME=Vectrabot

# Website Base URL (used for /website command and documentation links)
WEBSITE_URL=https://vectrabot-core.bot-hosting.net

# Port for the Next.js website (default: 3000)
PORT=3000

# --- LOGGING CONFIGURATION ---
# Channel ID where client logs will be formatted and broadcast using Components V2 Container layout
LOG_CHANNEL_ID=your_discord_admin_log_channel_id_here

# Audit Log Channel ID (for message edits, deletes, and member tracking)
AUDIT_LOG_CHANNEL_ID=your_discord_audit_log_channel_id_here

# Optional: Customize channels for specific log levels (no channel? no log broadcast)
INFO_LOG_CHANNEL_ID=your_discord_info_log_channel_id_here
WARN_LOG_CHANNEL_ID=your_discord_warn_log_channel_id_here
ERROR_LOG_CHANNEL_ID=your_discord_error_log_channel_id_here
COMMAND_LOG_CHANNEL_ID=your_discord_command_log_channel_id_here
